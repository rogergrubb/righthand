# === RIGHTHAND env template ===
# Copy to .env and fill in. Never commit .env.

# --- Core AI ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Model selection (override for cost tuning)
CLAUDE_REASONING_MODEL=claude-opus-4-6
CLAUDE_RETRIEVAL_MODEL=claude-haiku-4-5-20251001
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# --- Database ---
DATABASE_URL=postgresql://righthand:righthand@postgres:5432/righthand

# --- Single-user bootstrap ---
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
DEFAULT_USER_EMAIL=you@example.com

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# --- Frontend ---
VITE_BACKEND_WS=ws://localhost:8000
VITE_BACKEND_HTTP=http://localhost:8000

# --- File scanner ---
SCAN_ROOT=/workspace

# --- MCP integrations (fill as you connect them) ---
GITHUB_TOKEN=
GMAIL_OAUTH_JSON=
SLACK_BOT_TOKEN=
STRIPE_API_KEY=
LINEAR_API_KEY=

# --- Scheduled tasks ---
LESSONS_DAILY_CRON=0 22 * * *
TRENDS_DAILY_CRON=0 6 * * *
TIMEZONE=America/Chicago

# --- Self-modification guardrails ---
SELFMOD_ENABLED=false
SELFMOD_REQUIRE_VOICE_APPROVAL=true
SELFMOD_REPO=yourusername/righthand
SELFMOD_BRANCH_PREFIX=claude/

# --- Observability (v0.3) ---
POSTHOG_API_KEY=
SENTRY_DSN=
